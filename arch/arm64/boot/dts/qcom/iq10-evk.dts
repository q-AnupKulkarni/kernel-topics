			regulator-allow-set-load;
			regulator-allowed-modes = <RPMH_REGULATOR_MODE_LPM
						   RPMH_REGULATOR_MODE_HPM>;
		};

		vreg_s2l_cx: smps2 {
			regulator-name = "vreg_s2l_cx";
			regulator-min-microvolt = <300000>;
