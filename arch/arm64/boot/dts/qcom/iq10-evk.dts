	};

	/* PMIC L - Kai_MV - SID 0xB, Bus E0 */
	regulators-8 {
		compatible = "qcom,pmau0102-rpmh-regulators";
		qcom,pmic-id = "L_E0";

		/* LDO Regulators */
		vreg_l3l_1p8: ldo3 {
