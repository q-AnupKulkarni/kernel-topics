&soc {
	qupv3_2: geniqup@8c0000 {
		compatible = "qcom,nord-auto-geni-se-qup",
			     "qcom,sa8255p-geni-se-qup";

		uart15: serial@884000 {
			compatible = "qcom,nord-auto-geni-debug-uart",
				     "qcom,sa8255p-geni-debug-uart";
			power-domains = <&scmi11_pd 15>,
					<&scmi11_dvfs 15>;
			power-domain-names = "power",
					     "perf";
		};

		uart17: serial@88c000 {
			compatible = "qcom,nord-auto-geni-uart",
				     "qcom,sa8255p-geni-uart";
			power-domains = <&scmi11_pd 17>,
					<&scmi11_dvfs 17>;
			power-domain-names = "power",
					     "perf";
		};
	};

	qupv3_0: geniqup@9c0000 {
		compatible = "qcom,nord-auto-geni-se-qup",
			     "qcom,sa8255p-geni-se-qup";

		uart0: serial@980000 {
			compatible = "qcom,nord-auto-geni-uart",
				     "qcom,sa8255p-geni-uart";
			power-domains = <&scmi11_pd 0>,
					<&scmi11_dvfs 0>;
			power-domain-names = "power",
					     "perf";
		};

		uart3: serial@98c000 {
			compatible = "qcom,nord-auto-geni-uart",
				     "qcom,sa8255p-geni-uart";
			power-domains = <&scmi11_pd 3>,
					<&scmi11_dvfs 3>;
			power-domain-names = "power",
					     "perf";
		};

		uart4: serial@990000 {
			compatible = "qcom,nord-auto-geni-uart",
				     "qcom,sa8255p-geni-uart";
			power-domains = <&scmi11_pd 4>,
					<&scmi11_dvfs 4>;
			power-domain-names = "power",
					     "perf";
		};

		uart5: serial@994000 {
			compatible = "qcom,nord-auto-geni-uart",
				     "qcom,sa8255p-geni-uart";
			power-domains = <&scmi11_pd 5>,
					<&scmi11_dvfs 5>;
			power-domain-names = "power",
					     "perf";
		};
	};

	qupv3_1: geniqup@ac0000 {
		compatible = "qcom,nord-auto-geni-se-qup",
			     "qcom,sa8255p-geni-se-qup";

		uart9: serial@a88000 {
			power-domains = <&scmi11_pd 9>,
					<&scmi11_dvfs 9>;
			power-domain-names = "power",
					     "perf";
		};

		uart10: serial@a8c000 {
			power-domains = <&scmi11_pd 10>,
					<&scmi11_dvfs 10>;
			power-domain-names = "power",
					     "perf";
		};

		uart12: serial@a94000 {
			power-domains = <&scmi11_pd 12>,
					<&scmi11_dvfs 12>;
			power-domain-names = "power",
					     "perf";
		};
	};

	ufs_mem_hc: ufshc@1d44000 {
		compatible = "qcom,nord-auto-ufshc",
			     "qcom,sa8255p-ufshc";
		msi-parent = <&gic_its 0x14c0>;
		power-domains = <&scmi3_pd 0>;
	};

	adreno_smmu_0: iommu@3da0000 {
		power-domains = <&scmi15_pd 0>;
	};

	cpucp_sram: sram@18b3d000 {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "mmio-sram";
		reg = <0x0 0x18b3d000 0x0 0x400>;
		ranges = <0 0x0 0x18b3d000 0x400>;

		cpucp0_tx: cpucp-sram@0 {
			compatible = "arm,scmi-shmem";
			reg = <0x0 0x200>;
		};

		cpucp0_rx: cpcucp-sram@200 {
			compatible = "arm,scmi-shmem";
			reg = <0x200 0x200>;
		};
	};
};
